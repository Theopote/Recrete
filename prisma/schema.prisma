// Prisma schema for Recrete (砼憶)
// AI-assisted building renovation platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  architect
  engineer
  consultant
  project_manager
  owner
  viewer
}

enum ProjectStatus {
  draft
  survey
  diagnosis
  strategy
  design
  construction
  completed
  archived
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum BudgetLevel {
  low
  medium
  high
  premium
}

enum DocumentCategory {
  old_drawings
  survey_photos
  structure_documents
  mep_documents
  historical_documents
  cost_documents
  meeting_records
  reports
  others
}

enum DiagnosisCategory {
  architecture
  structure
  facade
  mep
  fire_safety
  accessibility
  energy
  heritage
  operation
}

enum SeverityLevel {
  low
  medium
  high
  critical
}

enum DiagnosisStatus {
  identified
  under_review
  confirmed
  resolved
}

enum StrategyType {
  light_renewal
  medium_renovation
  deep_recreation
  adaptive_reuse
  facade_upgrade
  energy_retrofit
  safety_upgrade
}

enum CostScheduleLevel {
  low
  medium
  high
}

enum IssueCategory {
  crack
  leakage
  spalling
  corrosion
  structure_exposure
  mep_conflict
  facade_damage
  fire_safety
  accessibility
  drawing_mismatch
  other
}

enum IssuePriority {
  low
  medium
  high
  urgent
}

enum IssueStatus {
  open
  in_progress
  resolved
  closed
}

enum ReportType {
  existing_condition_report
  diagnosis_report
  renovation_strategy_report
  owner_presentation
  government_submission
  site_issue_report
  design_meeting_summary
}

enum AIInsightType {
  missing_info
  risk
  opportunity
  design_strategy
  cost_warning
  schedule_warning
  compliance_warning
  site_issue
  report_suggestion
  data_conflict
}

enum AIInsightPriority {
  low
  medium
  high
  critical
}

enum AIInsightStatus {
  open
  acknowledged
  resolved
  dismissed
}

enum AITaskCategory {
  survey
  structure
  mep
  facade
  fire_safety
  documentation
  design
  compliance
  other
}

enum AITaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum AIAnalysisType {
  building_memory_update
  document_analysis
  missing_info_detection
  diagnosis_generation
  strategy_generation
  cost_risk_estimation
  report_generation
  copilot_chat
  conflict_detection
}

enum BimModelFormat {
  ifc
  dwg
  dxf
}

enum BimModelStatus {
  ready
  processing
  failed
  unsupported
}

enum DrawingType {
  floor_plan
  elevation
  section
  detail
  structural
  mep
  unknown
}

enum BackgroundJobType {
  document_ingest
  bim_cad_conversion
}

enum BackgroundJobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum AnalysisTaskStatus {
  queued
  processing
  completed
  failed
}

enum SourceEvidenceType {
  document
  photo
  site_issue
  user_note
  meeting_record
  diagnosis
}

enum ReportStatus {
  draft
  generating
  ready
  published
}

enum HeritageLevel {
  none
  local
  provincial
  national
  world
}

enum ComplianceOverallStatus {
  compliant
  partial
  non_compliant
}

enum ComplianceItemStatus {
  compliant
  non_compliant
  requires_verification
  not_applicable
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users    User[]
  projects Project[]
  aiUsageEvents AIUsageEvent[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  passwordHash   String?
  avatarUrl      String?
  role           UserRole @default(architect)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id])
  uploadedDocuments   DocumentAsset[]
  uploadedBimModels   BimModel[]
  assignedIssues      SiteIssue[]          @relation("AssignedIssues")
  assignedAITasks     AITask[]             @relation("AssignedAITasks")
  createdReports      Report[]
  aiConversations     AIConversation[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Project {
  id               String        @id @default(cuid())
  organizationId   String
  name             String
  code             String        @unique
  location         String
  buildingType     String
  originalFunction String
  currentFunction  String
  targetFunction   String
  constructionYear Int
  structureType    String
  floorCount       Int
  grossFloorArea   Float
  status           ProjectStatus @default(draft)
  renovationGoal   String
  budgetLevel      BudgetLevel   @default(medium)
  riskLevel        RiskLevel     @default(medium)
  healthScore           Int           @default(50)
  potentialScore        Int           @default(50)
  aiReadinessScore      Int           @default(50)
  dataCompletenessScore Int           @default(50)
  description           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  building        Building?
  buildingMemory  BuildingMemory?
  documents       DocumentAsset[]
  insights        AIInsight[]
  tasks           AITask[]
  analysisRuns    AIAnalysisRun[]
  evidence        SourceEvidence[]
  diagnosis       DiagnosisItem[]
  strategies      RenovationStrategy[]
  issues          SiteIssue[]
  reports         Report[]
  aiConversations AIConversation[]
  costRecords     ProjectCostRecord[]
  bimModels       BimModel[]
  drawingAssets   DrawingAsset[]
  backgroundJobs  BackgroundJob[]
  analysisTasks   DocumentAnalysisTaskRecord[]
  complianceRuns  ComplianceCheckRun[]
  complianceChecks ComplianceCheckRecord[]
}

model BuildingMemory {
  id                   String   @id @default(cuid())
  projectId            String   @unique
  summary              String   @db.Text
  knownFacts           String[]
  missingInformation   String[]
  keyRisks             String[]
  renovationPotential  String   @db.Text
  designConstraints    String[]
  ownerRequirements    String[]
  importantDecisions   String[]
  unresolvedQuestions  String[]
  lastUpdatedByAI      DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AIInsight {
  id             String            @id @default(cuid())
  projectId      String
  title          String
  type           AIInsightType
  priority       AIInsightPriority
  summary        String            @db.Text
  evidence       String?           @db.Text
  recommendation String?           @db.Text
  confidence     Float             @default(0.8)
  status         AIInsightStatus   @default(open)
  sourceType     String?
  sourceId       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   AITask[]
}

model AITask {
  id           String           @id @default(cuid())
  projectId    String
  insightId    String?
  title        String
  description  String           @db.Text
  category     AITaskCategory
  priority     AIInsightPriority
  status       AITaskStatus     @default(pending)
  assignedToId String?
  dueDate      DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  insight  AIInsight? @relation(fields: [insightId], references: [id])
  assignee User?     @relation("AssignedAITasks", fields: [assignedToId], references: [id])
}

model AIAnalysisRun {
  id                 String         @id @default(cuid())
  projectId          String
  analysisType       AIAnalysisType
  inputSummary       String         @db.Text
  outputSummary      String         @db.Text
  generatedItemCount Int            @default(0)
  modelName          String
  confidence         Float          @default(0.8)
  createdAt          DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SourceEvidence {
  id            String             @id @default(cuid())
  projectId     String
  sourceType    SourceEvidenceType
  sourceId      String?
  documentId    String?
  pageNumber    Int?
  locationLabel String?
  quote         String?            @db.Text
  boundingBox   String?
  confidence    Float              @default(0.8)
  createdAt     DateTime           @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Building {
  id               String        @id @default(cuid())
  projectId        String        @unique
  name             String
  address          String
  constructionYear Int
  structureType    String
  floorCount       Int
  basementCount    Int           @default(0)
  grossFloorArea   Float
  currentCondition String
  heritageLevel    HeritageLevel @default(none)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DocumentAsset {
  id           String           @id @default(cuid())
  projectId    String
  name         String
  type         String
  fileUrl      String
  fileSize     Int
  mimeType     String
  category     DocumentCategory
  aiSummary    String?          @db.Text
  extractedText String?         @db.Text
  description  String?
  uploadedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy    User?          @relation(fields: [uploadedById], references: [id])
  drawingAssets DrawingAsset[]
  analysisTasks DocumentAnalysisTaskRecord[]
}

model DiagnosisItem {
  id                     String            @id @default(cuid())
  projectId              String
  insightId              String?
  title                  String
  category               DiagnosisCategory
  severity               SeverityLevel
  status                 DiagnosisStatus   @default(identified)
  description            String
  evidence               String?
  recommendation         String?
  relatedLocation        String?
  requiresEngineerReview Boolean           @default(false)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model RenovationStrategy {
  id                   String            @id @default(cuid())
  projectId            String
  name                 String
  type                 StrategyType
  summary              String
  designGoal           String
  spatialStrategy      String
  structuralStrategy   String
  facadeStrategy       String
  mepStrategy          String
  costLevel            CostScheduleLevel
  scheduleLevel        CostScheduleLevel
  riskLevel            RiskLevel
  designValueScore     Int?
  feasibilityScore     Int?
  preservationScore    Int?
  pros                 String[]
  cons                 String[]
  recommendationReason String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model SiteIssue {
  id               String        @id @default(cuid())
  projectId        String
  title            String
  category         IssueCategory
  priority         IssuePriority
  status           IssueStatus   @default(open)
  location         String?
  description      String
  photoUrl         String?
  assignedToId     String?
  aiDetected       Boolean       @default(false)
  relatedInsightId String?
  dueDate          DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation("AssignedIssues", fields: [assignedToId], references: [id])
}

model Report {
  id          String       @id @default(cuid())
  projectId   String
  title       String
  type        ReportType
  content     String       @db.Text
  status        ReportStatus @default(draft)
  createdById   String?
  generatedByAI Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id])
}

model AIConversation {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  title     String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

/// Regional cost benchmarks aggregated from completed projects
model CostBenchmark {
  id            String   @id @default(cuid())
  region        String
  city          String?
  buildingType  String
  strategyType  String
  costPerSqmMin Float
  costPerSqmMax Float
  costPerSqmAvg Float
  sampleSize    Int      @default(0)
  source        String   @default("internal")
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([region, city, buildingType, strategyType])
  @@index([region, strategyType])
}

/// Actual cost records from completed renovation projects
model ProjectCostRecord {
  id               String   @id @default(cuid())
  projectId        String
  strategyType     String?
  actualCostPerSqm Float
  actualTotalCost  Float
  durationMonths   Int?
  outcome          String   @default("success")
  notes            String?  @db.Text
  region           String
  city             String?
  buildingType     String
  grossFloorArea   Float
  recordedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([strategyType, outcome])
  @@index([region, buildingType, strategyType])
}

/// Material price indices for cost estimation calibration
model MaterialPrice {
  id           String   @id @default(cuid())
  material     String
  materialZh   String
  unit         String
  pricePerUnit Float
  region       String
  trendPercent Float    @default(0)
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([region])
}

/// BIM / CAD model attached to a renovation project
model BimModel {
  id           String         @id @default(cuid())
  projectId    String
  name         String
  format       BimModelFormat
  status       BimModelStatus @default(processing)
  fileUrl      String
  previewUrl   String?
  gltfUrl      String?
  fileSize     Int
  mimeType     String
  errorMessage String?
  metadata     Json?
  uploadedById String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
}

/// Structured drawing analysis for a document page (vision + knowledge graph)
model DrawingAsset {
  id             String      @id @default(cuid())
  documentId     String
  projectId      String
  pageNumber     Int         @default(1)
  drawingType    DrawingType @default(unknown)
  scale          String?
  analysisResult Json
  knowledgeGraph Json?
  openCvResult   Json?
  modelName      String
  confidence     Float       @default(0.8)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  document DocumentAsset @relation(fields: [documentId], references: [id], onDelete: Cascade)
  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@index([projectId])
  @@index([drawingType])
}

/// Durable background job queue (replaces Next.js after() for async work)
model BackgroundJob {
  id          String              @id @default(cuid())
  type        BackgroundJobType
  status      BackgroundJobStatus @default(pending)
  projectId   String?
  payload     Json
  result      Json?
  error       String?             @db.Text
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(3)
  progress    Int                 @default(0)
  phase       String?
  message     String?
  runAfter    DateTime            @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, runAfter])
  @@index([projectId])
}

/// Persisted document analysis task progress (dual-mode with in-memory fallback)
model DocumentAnalysisTaskRecord {
  id           String             @id
  projectId    String
  documentId   String
  documentName String
  status       AnalysisTaskStatus @default(queued)
  phase        String             @default("queued")
  progress     Int                @default(0)
  message      String?
  error        String?            @db.Text
  jobId        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document DocumentAsset @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([documentId])
}

/// Persisted compliance engine run (rule evaluation snapshot)
model ComplianceCheckRun {
  id                String                  @id @default(cuid())
  projectId         String
  engineVersion     String
  overallCompliance ComplianceOverallStatus
  scenarios         String[]
  climateZone       String
  measurements      Json?
  summary           Json
  criticalIssues    String[]
  recommendations   String[]
  diagnosisApplied  Boolean                 @default(false)
  diagnosisCount    Int                     @default(0)
  createdAt         DateTime                @default(now())

  project Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checks  ComplianceCheckRecord[]

  @@index([projectId])
  @@index([projectId, createdAt])
}

/// Individual rule check result within a compliance run
model ComplianceCheckRecord {
  id            String               @id @default(cuid())
  runId         String
  projectId     String
  ruleId        String
  category      String
  codeRef       String
  codeId        String
  section       String
  requirement   String
  requirementZh String
  status        ComplianceItemStatus
  actualValue   String?
  requiredValue String
  note          String               @db.Text
  noteZh        String?
  priority      String
  remediation   String?              @db.Text

  run     ComplianceCheckRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  project Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([projectId])
  @@index([projectId, ruleId])
}

// ─── AI usage (Month 2: per-org quota) ───────────────────────────────────────

model AIUsageEvent {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  operation      String
  provider       String   @default("mock")
  modelName      String?
  success        Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, operation])
}
