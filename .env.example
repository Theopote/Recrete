DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recrete?schema=public"
USE_DATABASE="false"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="recrete-dev-secret-change-in-production"

# ── File storage (production: S3-compatible) ─────────────────
# local | s3
STORAGE_PROVIDER="local"
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_PUBLIC_URL_PREFIX=""
S3_FORCE_PATH_STYLE="false"

# ── AI service mode ──────────────────────────────────────────
# mock | openai | auto
# auto (default): use OpenAI when OPENAI_API_KEY is set, otherwise mock
AI_SERVICE="mock"
OPENAI_API_KEY=""

# Per-organization AI call limits (real API only)
AI_DAILY_ORG_LIMIT="50"
AI_MONTHLY_ORG_LIMIT="500"
AI_REQUEST_TIMEOUT_MS="60000"

# Legacy fallback for all text scenarios
OPENAI_MODEL="gpt-4o-mini"

# Scenario-based model routing (optional — overrides defaults per capability)
OPENAI_MODEL_FAST="gpt-4o-mini"          # document summary, lightweight tasks
OPENAI_MODEL_REASONING="gpt-4o"          # diagnosis, strategy, reports
OPENAI_MODEL_VISION="gpt-4o"             # drawing / photo analysis (OpenAI path)
OPENAI_MODEL_COMPLIANCE="gpt-4o-mini"    # compliance hybrid LLM layer
OPENAI_MODEL_COPILOT="gpt-4o-mini"       # project assistant chat
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# LangChain workflow orchestration (requires OPENAI_API_KEY + AI_SERVICE=openai)
LANGCHAIN_ENABLED="false"

# Vision provider: openai | anthropic (requires matching API key)
VISION_PROVIDER="openai"
ANTHROPIC_API_KEY=""
ANTHROPIC_VISION_MODEL="claude-sonnet-4-20250514"

# Pinecone vector search (optional — falls back to local TF-IDF)
PINECONE_API_KEY=""
PINECONE_INDEX="recrete-knowledge"
PINECONE_NAMESPACE="default"

# ── Background job queue ─────────────────────────────────────
# Without REDIS_URL: jobs dispatch via internal API (single-instance friendly)
# With REDIS_URL: BullMQ worker processes jobs (multi-instance safe)
REDIS_URL=""
JOB_RUNNER_SECRET="recrete-dev-job-secret"

# ── Trial pilot (Month 5) ────────────────────────────────────
# Set to "false" to hide the in-app feedback widget after pilot ends
NEXT_PUBLIC_TRIAL_FEEDBACK="true"

# ── Email (password reset) ───────────────────────────────────
# Leave SMTP_HOST empty to log reset links to console in development
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Recrete <noreply@recrete.io>"
